{
  "name": "trad",
  "version": "1.0.0",
  "description": "Petit outil local: tu parles dans le micro, le navigateur fait la reconnaissance vocale, puis on traduit via Google Translate.",
  "main": "electron/main.js",
  "scripts": {
    "start": "node ./electron/start.js",
    "model:fr": "node ./scripts/model.js fr",
    "model:fr:big": "node ./scripts/model.js fr big",
    "model:en": "node ./scripts/model.js en",
    "model:en:lgraph": "node ./scripts/model.js en lgraph",
    "model:en:big": "node ./scripts/model.js en big",
    "model:es": "node ./scripts/model.js es",
    "model:es:big": "node ./scripts/model.js es big",
    "model:de": "node ./scripts/model.js de",
    "model:de:big": "node ./scripts/model.js de big",
    "model:it": "node ./scripts/model.js it",
    "model:it:big": "node ./scripts/model.js it big",
    "model:all": "node ./scripts/model.js all",
    "model:all:big": "node ./scripts/model.js all big",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "npm run model:fr && electron-builder --mac dmg",
    "dist:win": "npm run model:fr && electron-builder --win nsis"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@lichess-org/vosk-browser": "^0.0.3",
    "adm-zip": "^0.5.17",
    "jszip": "^3.10.1",
    "tar": "^7.5.13",
    "vosk-browser": "^0.0.8"
  },
  "build": {
    "appId": "com.stevenbachimont.trad",
    "productName": "Trad Live",
    "files": [
      "**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "models/**",
      "node_modules/vosk-browser/dist/**"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
